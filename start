#!/usr/bin/env bash
#
# start - 一键拉起 Claude / Codex / Gemini / Codex2 四 pane 窗口
#
# 用法: start [项目目录]
#   不传目录则默认使用当前目录

DIR="${1:-$PWD}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CCG_DIR="$SCRIPT_DIR/.ccg"

if [ ! -d "$CCG_DIR" ]; then
    echo "Error: .ccg/ directory not found at $CCG_DIR"
    echo "Make sure .ccg/ is next to this start script."
    exit 1
fi

if [ ! -f "$DIR/CLAUDE.md" ]; then
    cat > "$DIR/CLAUDE.md" <<'EOF'
Read .ccg/AGENTS.md first on session start. Follow the collaboration protocol defined there.
Use python3 .ccg/iterm_chat.py say|ask|read to coordinate with Codex, Gemini, and Codex2 from this project root.
EOF
    echo "Created CLAUDE.md → $DIR/"
fi

python3 -u - "$DIR" << 'PYEOF'
import sys, subprocess, os, asyncio, re, datetime, traceback, shutil

d = sys.argv[1]
LOG = os.path.join(d, '.ccg', 'kick.log')
STAMP_DIR = os.path.join(d, '.ccg', '.pane_ids')
AGENT_ORDER = ['claude', 'codex', 'gemini', 'codex2']
DISPLAY_NAMES = {
    'claude': 'Claude',
    'codex': 'Codex',
    'gemini': 'Gemini',
    'codex2': 'Codex2',
}
STARTUP_BROADCASTS = {
    'claude': (
        'Startup role display: 请在当前 Claude pane 直接展示你的身份和工作职责。'
        '请说明：你是用户代理 / 架构师 / 协调者；负责理解用户需求、拆解任务、'
        '冻结契约、协调 Codex/Gemini/Codex2、收集汇报并最终向用户总结。'
        '只在当前窗口直接回复，不要调用其他 pane。'
    ),
    'codex': (
        'Claude startup coordination: 你已经作为 Codex pane 被拉起。'
        '请在当前 Codex 窗口直接展示你的身份、核心工作职责、主要负责的文件/任务类型、'
        '以及遇到 blocker 或完成任务时的汇报方式。'
        '注意：这次只在当前窗口直接回复，不要使用 .ccg/iterm_chat.py，不要转发给 Claude。'
    ),
    'gemini': (
        'Gemini pane uses a static pane title/badge for startup identity display.'
    ),
    'codex2': (
        'Claude startup coordination: 你已经作为 Codex2 verification pane 被拉起。'
        '请在当前 Codex2 窗口直接展示你的身份、核心工作职责、验证范围、'
        '以及你会如何报告测试命令、结果、风险和建议。'
        '注意：这次只在当前窗口直接回复，不要使用 .ccg/iterm_chat.py，不要转发给 Claude。'
    ),
}


def log(msg):
    ts = datetime.datetime.now().strftime('%H:%M:%S')
    line = f'[{ts}] {msg}'
    print(line, flush=True)
    with open(LOG, 'a') as f:
        f.write(line + '\n')


def strip_ansi(text):
    return re.compile(r'\x1b\[[0-9;]*[a-zA-Z]|\x1b\].*?\x07|\x1b\[.*?m').sub('', text)


async def screen_text(session):
    content = await session.async_get_screen_contents()
    raw = '\n'.join(content.line(j).string for j in range(content.number_of_lines))
    return strip_ansi(raw)


async def send_startup_message(agent, session):
    message = STARTUP_BROADCASTS[agent]
    await session.async_send_text(message)
    await asyncio.sleep(0.3)
    await session.async_send_text('\r')
    log(f"  [Claude → {DISPLAY_NAMES[agent]}] startup identity request sent")


def read_session_stamps():
    result = {}
    for agent in AGENT_ORDER:
        path = os.path.join(STAMP_DIR, f'{agent}.session')
        if not os.path.exists(path):
            continue
        try:
            sid = open(path).read().strip()
        except OSError:
            continue
        if sid:
            result[agent] = sid
    return result


log('=== start script beginning ===')

import iterm2

script = f'''tell application "iTerm2"
    set newWindow to (create window with default profile)

    tell current session of newWindow
        set name to "Claude Orchestrator"
        write text "bash '{d}/.ccg/launch_claude.sh' '{d}'" & return
        set rightTopSess to (split vertically with default profile)
    end tell

    tell rightTopSess
        set name to "Codex Engineer"
        write text "bash '{d}/.ccg/launch_codex.sh' '{d}'" & return
    end tell

    tell current session of newWindow
        set leftBottomSess to (split horizontally with default profile)
    end tell

    tell leftBottomSess
        set name to "Gemini UI/UX"
        write text "bash '{d}/.ccg/launch_gemini.sh' '{d}'" & return
    end tell

    tell rightTopSess
        set rightBottomSess to (split horizontally with default profile)
    end tell

    tell rightBottomSess
        set name to "Codex2 Verification"
        write text "bash '{d}/.ccg/launch_codex2.sh' '{d}'" & return
    end tell
end tell
'''


async def wait_for_team_tab(conn):
    for attempt in range(90):
        await asyncio.sleep(0.5)
        stamped = read_session_stamps()
        if len(stamped) != len(AGENT_ORDER):
            log(
                f'Attempt {attempt+1}: waiting for pane session stamps '
                f'({len(stamped)}/{len(AGENT_ORDER)})'
            )
            continue

        app = await iterm2.async_get_app(conn)
        for w in app.windows:
            for tab in w.tabs:
                sessions = list(tab.sessions)
                if len(sessions) != 4:
                    continue
                found = {agent: None for agent in AGENT_ORDER}
                for s in sessions:
                    for agent, sid in stamped.items():
                        if s.session_id == sid:
                            found[agent] = s
                            break
                if all(found.values()):
                    log(
                        f"Found team tab on attempt {attempt+1}, "
                        f"names: {[found[k].name for k in AGENT_ORDER]}, "
                        f"sessions: {[found[k].session_id for k in AGENT_ORDER]}"
                    )
                    return found

        log(
            f'Attempt {attempt+1}: have full stamps but exact team tab not ready yet; '
            f'stamped sessions={[stamped[a] for a in AGENT_ORDER]}'
        )

    return None


async def kick_all():
    conn = await iterm2.Connection().async_create()
    app = await iterm2.async_get_app(conn)
    old_ids = [
        s.session_id
        for w in app.windows
        for tab in w.tabs
        for s in tab.sessions
    ]
    log(f'Collected {len(old_ids)} existing session IDs before window creation')

    shutil.rmtree(STAMP_DIR, ignore_errors=True)
    os.makedirs(STAMP_DIR, exist_ok=True)
    log(f'Reset pane session stamp dir → {STAMP_DIR}')

    log('Running AppleScript to create window...')
    subprocess.run(['osascript', '-e', script], check=True)
    log('AppleScript done, waiting for window to appear...')

    target = await wait_for_team_tab(conn)
    if not target:
        log('ERROR: Could not find team window after 45s')
        return

    sessions_file = os.path.join(d, '.ccg', '.sessions')
    with open(sessions_file, 'w') as f:
        for agent in AGENT_ORDER:
            f.write(f"{agent}:{target[agent].session_id}\n")
    log(f'Saved session IDs → {sessions_file}')

    prompt_patterns = [
        r'trust', r'agree', r'accept', r'continue', r'\byes\b',
        r'confirm', r'press enter', r'update', r'upgrade', r'enter to confirm',
    ]
    generic_ready_patterns = [r'shift\+tab', r'shell mode']
    codex_ready_patterns = [
        r'\? for shortcuts',
        r'try ".*"',
        r'esc to interrupt',
        r'ideas? try',
        r'gpt-.*·',
        r'(^|\n)› ',
    ]
    gemini_ready_patterns = [r'type your message', r'@path/to/file', r'gemini cli', r'quota', r'for shortcuts']
    codex_failed_patterns = [r'command not found', r'please restart codex']
    codex_launched = {agent: False for agent in ('codex', 'codex2')}
    ready_agents = set()

    for round_num in range(8):
        await asyncio.sleep(5)
        all_ready = True

        for agent in AGENT_ORDER:
            session = target[agent]
            label = DISPLAY_NAMES[agent]
            is_claude = (agent == 'claude')
            is_gemini = (agent == 'gemini')
            is_codex_like = (agent in ('codex', 'codex2'))

            try:
                screen = (await screen_text(session)).lower()
            except Exception as e:
                log(f'  [{label}] read failed: {e}')
                continue

            last_lines = [l.strip() for l in screen.split('\n')[-5:] if l.strip()]
            log(f'  [{label}] round {round_num+1} last: {last_lines[:3]}')

            # Claude 交互式启动链路对“自动 Enter / 自动确认”比较敏感。
            # 只处理 bare 模式下明确的 API key 确认框；其他情况不主动干预，
            # 避免把会话推进到异常状态。
            if is_claude:
                if 'do you want to use this api key' in screen:
                    all_ready = False
                    await session.async_send_text('1')
                    await asyncio.sleep(0.3)
                    await session.async_send_text('\r')
                    log(f"  [{label}] API key prompt → sent '1 + Enter'")
                else:
                    ready_agents.add(agent)
                    log(f'  [{label}] skipping auto-input to avoid interfering with Claude startup')
                continue

            if is_codex_like:
                if any(re.search(p, screen) for p in codex_ready_patterns):
                    ready_agents.add(agent)
                    log(f'  [{label}] Codex ready, skipping')
                    continue
                if any(re.search(p, screen, re.MULTILINE) for p in codex_failed_patterns):
                    all_ready = False
                    if not codex_launched[agent]:
                        codex_launched[agent] = True
                        await session.async_send_text('codex\r')
                        log(f'  [{label}] detected failed launch → relaunched codex once')
                    else:
                        log(f'  [{label}] launch still failing, not relaunching again')
                    continue
                if 'codex' in screen:
                    all_ready = False
                    log(f'  [{label}] Codex appears to be launching, not sending duplicate input')
                    continue

            if any(re.search(p, screen) for p in generic_ready_patterns):
                ready_agents.add(agent)
                log(f'  [{label}] already ready, skipping')
                continue

            # Gemini's TUI redraws aggressively during onboarding/auth. Do not
            # send automatic Escape/Enter/confirm keys here; it causes visible
            # flicker and can bounce the UI between states.
            if is_gemini:
                if any(re.search(p, screen) for p in gemini_ready_patterns):
                    ready_agents.add(agent)
                    log(f'  [{label}] Gemini ready, skipping')
                    continue
                all_ready = False
                log(f'  [{label}] observing only during startup to avoid TUI flicker')
                continue

            if any(re.search(p, screen) for p in prompt_patterns):
                all_ready = False
                await session.async_send_text('1')
                await asyncio.sleep(0.3)
                await session.async_send_text('\r')
                log(f"  [{label}] detected prompt → sent '1 + Enter'")
            else:
                all_ready = False
                log(f'  [{label}] not ready yet, not sending Enter')

        if all_ready:
            log('All panes ready!')
            break
    else:
        log('Reached max rounds, some panes may still need manual action')

    log('Claude startup coordination: asking ready panes to display identity and responsibilities...')
    for agent in ('claude', 'codex', 'gemini', 'codex2'):
        if agent == 'gemini':
            log('  [Claude → Gemini] skipped startup prompt; Gemini role is shown by pane title/badge')
            continue
        if agent not in ready_agents:
            log(f'  [Claude → {DISPLAY_NAMES[agent]}] skipped startup message because pane is not ready')
            continue
        try:
            await send_startup_message(agent, target[agent])
            await asyncio.sleep(0.8)
        except Exception as e:
            log(f'  [Claude → {DISPLAY_NAMES[agent]}] startup message failed: {e}')


try:
    asyncio.run(kick_all())
except Exception:
    log('ERROR: start script crashed')
    log(traceback.format_exc())
    raise

PYEOF
