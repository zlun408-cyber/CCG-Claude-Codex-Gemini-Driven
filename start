#!/usr/bin/env bash
#
# start - 一键拉起 Claude Code / Codex / Gemini 三 pane 窗口
#
# 用法: start [项目目录]
#   不传目录则默认使用当前目录

DIR="${1:-$PWD}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CCG_DIR="$SCRIPT_DIR/.ccg"

# 确保 .ccg/ 目录存在
if [ ! -d "$CCG_DIR" ]; then
    echo "Error: .ccg/ directory not found at $CCG_DIR"
    echo "Make sure .ccg/ is next to this start script."
    exit 1
fi

# 如果目标目录没有 CLAUDE.md，自动生成一个
if [ ! -f "$DIR/CLAUDE.md" ]; then
    echo "Read .ccg/AGENTS.md first on session start. Follow the collaboration protocol defined there." > "$DIR/CLAUDE.md"
    echo "Created CLAUDE.md → $DIR/"
fi

CLAUDE_B64=$(echo -n "Claude" | base64)
CODEX_B64=$(echo -n "Codex" | base64)
GEMINI_B64=$(echo -n "Gemini" | base64)

# 生成并执行 AppleScript：创建窗口 + 智能确认
python3 - "$DIR" "$CLAUDE_B64" "$CODEX_B64" "$GEMINI_B64" << 'PYEOF'
import sys, subprocess, os, asyncio, re, datetime

d, c, cx, g = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
LOG = os.path.join(d, '.ccg', 'kick.log')

def log(msg):
    ts = datetime.datetime.now().strftime("%H:%M:%S")
    line = f"[{ts}] {msg}"
    print(line)
    with open(LOG, 'a') as f:
        f.write(line + "\n")

log("=== start script beginning ===")

import iterm2

# 关键：在创建窗口之前先收集已有 session ID
conn = asyncio.get_event_loop().run_until_complete(iterm2.Connection().async_create())
app = asyncio.get_event_loop().run_until_complete(iterm2.async_get_app(conn))
old_ids = set()
for w in app.windows:
    for tab in w.tabs:
        for s in tab.sessions:
            old_ids.add(s.session_id)
log(f"Collected {len(old_ids)} existing session IDs before window creation")

# 用 AppleScript 创建新窗口
script = f'''tell application "iTerm2"
    set newWindow to (create window with default profile)

    tell current session of newWindow
        set name to "Claude"
        write text "cd '{d}' && printf '\\\\033]1337;SetBadgeFormat={c}\\\\007' && claude" & return
        set codexSess to (split vertically with default profile)
    end tell

    tell codexSess
        set name to "Codex"
        write text "cd '{d}' && printf '\\\\033]1337;SetBadgeFormat={cx}\\\\007' && codex" & return
        set geminiSess to (split vertically with default profile)
    end tell

    tell geminiSess
        set name to "Gemini"
        write text "cd '{d}' && printf '\\\\033]1337;SetBadgeFormat={g}\\\\007' && gemini" & return
    end tell
end tell
'''

log("Running AppleScript to create window...")
subprocess.run(["osascript", "-e", script])
log("AppleScript done, waiting for window to appear...")

async def kick_all():
    # 重新创建连接，确保能看到新窗口
    kick_conn = await iterm2.Connection().async_create()
    app = await iterm2.async_get_app(kick_conn)

    # 等新窗口出现（old_ids 是窗口创建前收集的）
    target = None
    for attempt in range(30):
        await asyncio.sleep(0.5)
        app = await iterm2.async_get_app(conn)
        for w in app.windows:
            for tab in w.tabs:
                sessions = tab.sessions
                if len(sessions) == 3 and any(s.session_id not in old_ids for s in sessions):
                    target = list(sessions)
                    log(f"Found team window on attempt {attempt+1}, sessions: {[s.session_id for s in sessions]}")
                    break
            if target:
                break
        if target:
            break

    if not target:
        log("ERROR: Could not find team window after 15s")
        return

    # 保存 session ID，供 iterm_chat.py 精准定位
    sessions_file = os.path.join(d, '.ccg', '.sessions')
    names = ['claude', 'codex', 'gemini']
    with open(sessions_file, 'w') as f:
        for name, s in zip(names, target):
            f.write(f"{name}:{s.session_id}\n")
    log(f"Saved session IDs → {sessions_file}")

    # 智能确认：读屏幕内容，检测确认提示，按需发送正确按键
    def strip_ansi(text):
        """去除 ANSI 转义码，只保留纯文本。"""
        return re.compile(r'\x1b\[[0-9;]*[a-zA-Z]|\x1b\].*?\x07|\x1b\[.*?m').sub('', text)

    # 需要自动同意的关键词（信任确认、升级提示等）
    PROMPT_PATTERNS = [
        r'trust',
        r'agree',
        r'accept',
        r'continue',
        r'\byes\b',
        r'confirm',
        r'press enter',
        r'update',
        r'upgrade',
        r'enter to confirm',
    ]

    # 已经就绪的关键词（说明不需要任何操作）
    READY_PATTERNS = [
        r'shift\+tab',
        r'shell mode',
    ]

    pane_names = ['Claude', 'Codex', 'Gemini']

    for round_num in range(5):  # 最多 5 轮
        await asyncio.sleep(5)
        all_ready = True

        for i, s in enumerate(target):
            is_gemini = (i == 2)

            try:
                content = await s.async_get_screen_contents()
                raw = "\n".join(
                    content.line(j).string
                    for j in range(content.number_of_lines)
                )
                screen = strip_ansi(raw)
            except Exception as e:
                log(f"  [{pane_names[i]}] read failed: {e}")
                continue

            screen_lower = screen.lower()

            # 调试：记录最后几行
            last_lines = [l.strip() for l in screen.split('\n')[-5:] if l.strip()]
            log(f"  [{pane_names[i]}] round {round_num+1} last: {last_lines[:3]}")

            # 如果已经在就绪状态，跳过
            if any(re.search(p, screen_lower) for p in READY_PATTERNS):
                log(f"  [{pane_names[i]}] already ready, skipping")
                continue

            # Gemini 已就绪但没匹配到 READY 关键词 → 也跳过，不乱发按键
            if is_gemini and round_num >= 1:
                # 第二轮起，如果 Gemini 没有 prompt 关键词，不发送任何东西
                if not any(re.search(p, screen_lower) for p in PROMPT_PATTERNS):
                    log(f"  [{pane_names[i]}] Gemini no prompt, skipping to avoid shell mode")
                    continue

            # 检测是否有确认提示
            if any(re.search(p, screen_lower) for p in PROMPT_PATTERNS):
                all_ready = False
                if is_gemini:
                    # Gemini: 先 Escape 再操作，避免进入 shell mode
                    await s.async_send_text('\x1b')
                    await asyncio.sleep(0.3)
                await s.async_send_text('1')
                await asyncio.sleep(0.3)
                await s.async_send_text('\r')
                log(f"  [{pane_names[i]}] detected prompt → sent '1 + Enter'")
            else:
                # 没检测到提示词，也没就绪
                if is_gemini:
                    # Gemini 不发 Enter，避免触发 shell mode
                    log(f"  [{pane_names[i]}] Gemini: no prompt, not sending Enter (avoid shell mode)")
                else:
                    all_ready = False
                    await s.async_send_text('\r')
                    log(f"  [{pane_names[i]}] no prompt detected → sent Enter")

        if all_ready:
            log("All panes ready!")
            break
    else:
        log("Reached max rounds, some panes may still need manual action")

asyncio.run(kick_all())

PYEOF
